<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<title>Generala Multiplayer</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{
  height:100%;background:#0b5d2a;
  font-family:'Segoe UI',monospace;color:white;overflow:hidden;
  user-select:none;-webkit-user-select:none;
}
#modal{
  position:fixed;inset:0;background:#000c;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding:20px;
}
#modal h2{font-size:22px;margin-bottom:8px;letter-spacing:2px;}
#modal .id-box{
  background:#ffffff22;border:1px solid #fff4;
  padding:10px 20px;border-radius:8px;font-size:22px;letter-spacing:4px;font-weight:bold;
}
#modal input{
  padding:10px 14px;font-size:18px;border-radius:8px;border:none;
  background:#ffffffdd;color:#000;width:180px;text-align:center;letter-spacing:4px;
}
#modal button{
  padding:12px 32px;font-size:18px;border-radius:8px;border:none;
  background:#4caf50;color:white;cursor:pointer;font-weight:bold;
}
#modal .hint{font-size:12px;color:#aaa;margin-top:6px;}

#game{display:none;flex-direction:column;height:100vh;}

#turnBanner{
  text-align:center;padding:8px;font-size:13px;font-weight:bold;letter-spacing:1px;
  background:#00000044;
}
#turnBanner.mine{background:#2e7d3288;}
#turnBanner.theirs{background:#7d2e2e88;}

#scoreboard{
  display:grid;grid-template-columns:1fr 1fr;
  background:#00000033;padding:6px 8px;gap:3px;
}
.score-col h3{font-size:11px;text-align:center;margin-bottom:4px;opacity:0.7;text-transform:uppercase;letter-spacing:1px;}
.score-col.active-player h3{color:#7eff8a;}
.score-row{
  display:flex;justify-content:space-between;
  font-size:11px;padding:3px 6px;border-radius:4px;background:#ffffff0a;
}
.score-row.clickable{background:#4caf5033;border:1px solid #4caf5077;cursor:pointer;}
.score-row.clickable:active{background:#4caf5055;}
.score-row.locked{color:#aaa;}
.score-row.preview-val .val{color:#ffe57f;}
.score-row.invalid{color:#555;background:#ffffff05;}
.score-row .label{font-weight:bold;}
.score-row .val{font-weight:bold;}

#diceWrap{
  flex:1;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:14px;
}
#diceArea{display:flex;gap:14px;justify-content:center;align-items:center;}

.die-wrap{width:58px;height:58px;perspective:200px;cursor:pointer;}
.die-inner{width:100%;height:100%;position:relative;transform-style:preserve-3d;transition:transform 0.15s;}
.die-wrap:active .die-inner{transform:scale(0.92);}
.die-face{
  position:absolute;inset:0;
  background:linear-gradient(145deg,#fff 0%,#ddd 100%);
  border-radius:10px;
  box-shadow:inset -3px -3px 6px rgba(0,0,0,0.25),inset 2px 2px 5px rgba(255,255,255,0.8),3px 6px 14px rgba(0,0,0,0.5);
}
.die-wrap.held .die-face{
  background:linear-gradient(145deg,#ffe082,#ffb300);
  box-shadow:inset -3px -3px 6px rgba(0,0,0,0.2),inset 2px 2px 5px rgba(255,255,255,0.5),3px 6px 14px rgba(0,0,0,0.5),0 0 10px #ffb30066;
}
.pip{
  width:9px;height:9px;
  background:radial-gradient(circle at 35% 35%,#555,#000);
  border-radius:50%;position:absolute;
}
.rollAnim .die-inner{animation:rollAnim 0.35s ease;}
@keyframes rollAnim{
  0%{transform:rotateX(0) rotateY(0);}
  40%{transform:rotateX(180deg) rotateY(90deg) scale(1.1);}
  100%{transform:rotateX(360deg) rotateY(360deg);}
}

#rollBtn{
  padding:12px 36px;font-size:17px;font-weight:bold;
  border-radius:50px;border:none;cursor:pointer;
  background:linear-gradient(145deg,#43a047,#1b5e20);
  color:white;letter-spacing:1px;
  box-shadow:0 4px 12px #0007;
  transition:opacity 0.2s,transform 0.1s;
}
#rollBtn:disabled{opacity:0.35;cursor:default;}
#rollBtn:not(:disabled):active{transform:scale(0.96);}
#rollInfo{font-size:12px;color:#aaa;text-align:center;}

#winner{
  position:fixed;inset:0;background:#000d;
  display:none;align-items:center;justify-content:center;
  flex-direction:column;gap:12px;font-size:28px;text-align:center;
}
</style>
</head>
<body>

<div id="modal">
  <h2>🎲 GENERALA</h2>
  <div class="hint">Your room code</div>
  <div class="id-box" id="myId">…</div>
  <div class="hint" style="margin-top:12px">Enter opponent's code</div>
  <input id="peerId" placeholder="0000" maxlength="8">
  <button onclick="connectPeer()">Connect</button>
</div>

<div id="game">
  <div id="turnBanner">—</div>
  <div id="scoreboard"></div>
  <div id="diceWrap">
    <div id="diceArea"></div>
    <div id="rollInfo"></div>
    <button id="rollBtn" onclick="doRoll()" disabled>🎲 Roll (0/3)</button>
  </div>
</div>

<div id="winner"></div>

<script>
const WS_URL = "wss://minds-amd-frames-heavy.trycloudflare.com";
let ws = new WebSocket(WS_URL);

let myId = null;
let peer = null;
let isHost = false;       // true = this client owns game logic
let state = null;

// ── SEND ──
// Wraps an object in the relay's message envelope
function send(obj){
  ws.send(JSON.stringify({type:"message", text:JSON.stringify(obj)}));
}

// ── STATE HELPERS ──
function emptyScore(){
  return {ones:null,twos:null,threes:null,fours:null,fives:null,sixes:null,
          escalera:null,full:null,poker:null,generala:null,doble:null};
}
function initialState(hostId, guestId){
  return {
    turn: guestId,  // connector (guest) goes first
    roll: 0,
    dice: [1,1,1,1,1],
    held: [false,false,false,false,false],
    scores: {
      [hostId]: emptyScore(),
      [guestId]: emptyScore()
    }
  };
}

// ── WS HANDLER ──
ws.onmessage = e => {
  const msg = JSON.parse(e.data);

  // Server assigned us an ID
  if(msg.type === "id"){
    myId = msg.id;
    document.getElementById("myId").innerText = myId;
  }

  // Server notifies both sides that a connection was established
  // msg.with = the OTHER player's ID
  if(msg.type === "connected"){
    peer = msg.with;
    if(myId < peer){
      // Lower ID = host: initialize and send state
      isHost = true;
      state = initialState(myId, peer);
      send({type:"state", state});
      startGame();
    }
    // Higher ID = guest: just wait for state from host
  }

  if(msg.type === "message"){
    const data = JSON.parse(msg.text);

    if(data.type === "state"){
      state = data.state;
      // Connector path: derive peer from state if not yet set
      if(!peer){
        peer = Object.keys(state.scores).find(id => id !== myId);
      }
      const gameEl = document.getElementById("game");
      if(gameEl.style.display === "none" || gameEl.style.display === ""){
        startGame();
      } else {
        render();
      }
    }

    if(data.type === "action" && isHost){
      handleAction(data);
    }
  }
};

// ── PLAYER ACTIONS (sent to host) ──
function isMyTurn(){ return state && state.turn === myId; }

function doRoll(){
  if(!isMyTurn() || state.roll >= 3) return;
  if(isHost) handleAction({action:"roll"});
  else send({type:"action", action:"roll"});
}

function doToggle(i){
  if(!isMyTurn() || state.roll === 0) return;
  if(isHost) handleAction({action:"toggle", i});
  else send({type:"action", action:"toggle", i});
}

function doScore(cat){
  if(!isMyTurn() || state.scores[myId][cat] !== null) return;
  if(isHost) handleAction({action:"score", cat});
  else send({type:"action", action:"score", cat});
}

// ── HOST LOGIC ──
function handleAction(a){
  if(a.action === "roll"){
    if(state.roll >= 3) return;
    for(let i = 0; i < 5; i++)
      if(!state.held[i]) state.dice[i] = 1 + (Math.random()*6|0);
    state.roll++;
    broadcastState(true);
  }

  if(a.action === "toggle"){
    if(state.roll === 0) return;
    state.held[a.i] = !state.held[a.i];
    broadcastState();
  }

  if(a.action === "score"){
    state.scores[state.turn][a.cat] = computeScore(a.cat, state);
    if(gameOver()){
      endGame();
      return;
    }
    state.roll = 0;
    state.held = [false,false,false,false,false];
    state.turn = (state.turn === myId) ? peer : myId;
    broadcastState();
  }
}

function broadcastState(anim=false){
  send({type:"state", state});
  render(anim);
}

// ── SCORING ──
function dCount(d,n){ return d.filter(x=>x===n).length; }
function dSum(d,n){ return d.filter(x=>x===n).reduce((a,b)=>a+b,0); }
function isStraight(d){ const s=[...d].sort().join(""); return s==="12345"||s==="23456"; }

function computeScore(cat, st){
  const d = st.dice, firstRoll = st.roll === 1;
  if(cat==="ones")    return dSum(d,1);
  if(cat==="twos")    return dSum(d,2);
  if(cat==="threes")  return dSum(d,3);
  if(cat==="fours")   return dSum(d,4);
  if(cat==="fives")   return dSum(d,5);
  if(cat==="sixes")   return dSum(d,6);
  if(cat==="escalera") return isStraight(d) ? (firstRoll?25:20) : 0;
  if(cat==="full"){
    const set=new Set(d);
    if(set.size===2 && [...set].some(x=>dCount(d,x)===3)) return firstRoll?35:30;
    return 0;
  }
  if(cat==="poker")   return d.some(v=>dCount(d,v)>=4) ? (firstRoll?45:40) : 0;
  if(cat==="generala") return new Set(d).size===1 ? (firstRoll?60:50) : 0;
  if(cat==="doble"){
    if(new Set(d).size===1 && st.scores[st.turn].generala!==null) return 100;
    return 0;
  }
  return 0;
}

function canScore(cat, st){
  const d = st.dice;
  if(cat==="ones")    return dSum(d,1)>0;
  if(cat==="twos")    return dSum(d,2)>0;
  if(cat==="threes")  return dSum(d,3)>0;
  if(cat==="fours")   return dSum(d,4)>0;
  if(cat==="fives")   return dSum(d,5)>0;
  if(cat==="sixes")   return dSum(d,6)>0;
  if(cat==="escalera") return isStraight(d);
  if(cat==="full"){
    const set=new Set(d);
    return set.size===2 && [...set].some(x=>dCount(d,x)===3);
  }
  if(cat==="poker")    return d.some(v=>dCount(d,v)>=4);
  if(cat==="generala") return new Set(d).size===1;
  if(cat==="doble")    return new Set(d).size===1 && st.scores[st.turn]?.generala!==null;
  return false;
}

// ── GAME OVER ──
function gameOver(){
  return Object.values(state.scores[myId]).every(v=>v!==null) &&
         Object.values(state.scores[peer]).every(v=>v!==null);
}
function total(id){
  return Object.values(state.scores[id]).reduce((a,b)=>a+(b||0),0);
}
function endGame(){
  const t1=total(myId), t2=total(peer);
  const msg = t1>t2?"🏆 YOU WIN!":t1<t2?"😔 YOU LOSE":"🤝 DRAW";
  const w = document.getElementById("winner");
  w.innerHTML=`<div>${msg}</div><div style="font-size:20px">${t1} – ${t2}</div>`;
  w.style.display="flex";
  send({type:"state", state});
  render();
}

// ── RENDER ──
const CAT_LABELS={
  ones:"Ones", twos:"Twos", threes:"Threes", fours:"Fours", fives:"Fives", sixes:"Sixes",
  escalera:"Straight (20/25)", full:"Full House (30/35)", poker:"Four of a Kind (40/45)",
  generala:"Generala (50/60)", doble:"Double Generala (100)"
};

const PIP_MAP={
  1:[[50,50]],
  2:[[22,22],[78,78]],
  3:[[22,22],[50,50],[78,78]],
  4:[[22,22],[78,22],[22,78],[78,78]],
  5:[[22,22],[78,22],[50,50],[22,78],[78,78]],
  6:[[22,22],[78,22],[22,50],[78,50],[22,78],[78,78]]
};

function buildDie(val, held, anim){
  const wrap = document.createElement("div");
  wrap.className = "die-wrap" + (held?" held":"") + (anim?" rollAnim":"");
  const inner = document.createElement("div");
  inner.className = "die-inner";
  const face = document.createElement("div");
  face.className = "die-face";
  PIP_MAP[val].forEach(([px,py])=>{
    const p = document.createElement("div");
    p.className = "pip";
    p.style.left = (px/100*58-4.5)+"px";
    p.style.top  = (py/100*58-4.5)+"px";
    face.appendChild(p);
  });
  inner.appendChild(face);
  wrap.appendChild(inner);
  return wrap;
}

function render(anim=false){
  if(!state || !peer) return;

  const myTurn = isMyTurn();
  const rolled  = state.roll > 0;

  // Banner
  const banner = document.getElementById("turnBanner");
  banner.textContent = myTurn ? "⬤ YOUR TURN" : "⬤ OPPONENT'S TURN";
  banner.className = myTurn ? "mine" : "theirs";

  // Dice
  const diceArea = document.getElementById("diceArea");
  diceArea.innerHTML = "";
  state.dice.forEach((v,i)=>{
    const d = buildDie(v, state.held[i], anim && !state.held[i]);
    if(myTurn && rolled) d.onclick = ()=>doToggle(i);
    diceArea.appendChild(d);
  });

  // Roll button & hint
  const rollBtn = document.getElementById("rollBtn");
  const rollInfo = document.getElementById("rollInfo");
  rollBtn.disabled = !myTurn || state.roll >= 3;
  rollBtn.textContent = `🎲 Roll (${state.roll}/3)`;
  rollInfo.textContent = !myTurn ? "Waiting for opponent…"
    : rolled ? "Tap dice to hold · then roll again or pick a score"
             : "Tap Roll to start your turn";

  // Scoreboard
  const sb = document.getElementById("scoreboard");
  sb.innerHTML = "";
  [myId, peer].forEach(pid=>{
    const col = document.createElement("div");
    col.className = "score-col" + (state.turn===pid?" active-player":"");
    const h = document.createElement("h3");
    h.textContent = (pid===myId?"You":"Opponent") + " · " + total(pid) + " pts";
    col.appendChild(h);

    Object.keys(emptyScore()).forEach(cat=>{
      const row = document.createElement("div");
      row.className = "score-row";
      const lbl = document.createElement("span");
      lbl.className = "label";
      lbl.textContent = CAT_LABELS[cat];
      const val = document.createElement("span");
      val.className = "val";

      const stored = state.scores[pid][cat];
      if(stored !== null){
        val.textContent = stored;
        row.classList.add("locked");
      } else if(pid===myId && myTurn && rolled){
        if(canScore(cat, state)){
          val.textContent = "+" + computeScore(cat, state);
          row.classList.add("clickable","preview-val");
          row.onclick = ()=>doScore(cat);
        } else {
          val.textContent = "–";
          row.classList.add("invalid");
        }
      }

      row.appendChild(lbl);
      row.appendChild(val);
      col.appendChild(row);
    });

    sb.appendChild(col);
  });
}

// ── START ──
function startGame(){
  document.getElementById("modal").style.display = "none";
  document.getElementById("game").style.display = "flex";
  render();
}

function connectPeer(){
  ws.send(JSON.stringify({type:"connect", target:document.getElementById("peerId").value}));
}
</script>
</body>
</html>